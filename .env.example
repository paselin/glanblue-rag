# LLM Configuration (ローカルLLM対応)
# ローカルLLM使用時はダミーキーでOK
OPENAI_API_KEY=dummy-key
OPENAI_API_BASE=http://localhost:1234/v1
OPENAI_MODEL=gpt-4-turbo-preview
OPENAI_TEMPERATURE=0.7
OPENAI_MAX_TOKENS=2000

# Embeddings Configuration - HuggingFace (完全無料)
EMBEDDING_PROVIDER=huggingface
EMBEDDING_MODEL=intfloat/multilingual-e5-large
EMBEDDING_DEVICE=cpu

# OpenAI Embeddings (EMBEDDING_PROVIDER=openai の場合のみ使用)
# OPENAI_EMBEDDING_MODEL=text-embedding-3-small
# OPENAI_EMBEDDING_API_KEY=sk-your-key-here
# OPENAI_EMBEDDING_API_BASE=https://api.openai.com/v1

# Application Settings
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=INFO

# Vector Database
CHROMA_PERSIST_DIR=./data/vector_db
COLLECTION_NAME=granblue_knowledge

# Redis Cache
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

# Database
DATABASE_URL=sqlite:///./data/app.db

# Scraping Settings
SCRAPER_USER_AGENT=Mozilla/5.0 (Macintosh; Intel Mac OS X 10_15_7)
SCRAPER_DELAY=2
SCRAPER_TIMEOUT=30000

# Rate Limiting
RATE_LIMIT_PER_HOUR=100
